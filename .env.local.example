# Local environment example (safe template)
# Copy this file to `.env.local` for local development and DO NOT commit `.env.local`.
# `.env.local` overrides `.env` on startup so local secrets stay out of shared files.
# Use strong, unique secrets for each environment and rotate after any exposure.

# MongoDB connection string (use a dedicated user with limited privileges)
MONGODB_URI=mongodb://localhost:27017/helios_local

# Session secret (generate at least 48 bytes hex)
# e.g. run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-strong-session-secret

# Note encryption key (32 bytes). Accepts either 64-hex or base64-32.
# e.g. hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOTE_ENCRYPTION_KEY=replace-with-64-char-hex-or-base64-32

# Optional legacy keys for migration. Set to blank for new installs.
LEGACY_NOTE_ENCRYPTION_KEY=
ALLOW_LEGACY_SESSION_SECRET_FALLBACK=false

# Optional Google OAuth (only necessary if enabling Google sign-in)
# Set APP_BASE_URL to the exact local URL registered with Google.
# APP_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional metrics access token for local scraping or dashboard integration.
# Send it with Authorization: Bearer <token> or X-Metrics-Token.
METRICS_AUTH_TOKEN=
