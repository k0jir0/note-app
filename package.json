{
  "name": "note-app",
  "version": "0.1.0",
  "description": "A full-stack note-taking and security-research application with authentication, encrypted notes, and security analysis dashboards",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start-dev": "node index.js",
    "local:run": "powershell -ExecutionPolicy Bypass -File .\\run-local.ps1",
    "local:health": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-local-health.ps1",
    "local:run:worker": "powershell -ExecutionPolicy Bypass -File .\\run-local.ps1 -WithWorker",
    "sandbox:up": "docker compose -f docker-compose.sandbox.yml up --build -d",
    "sandbox:down": "docker compose -f docker-compose.sandbox.yml down",
    "sandbox:logs": "docker compose -f docker-compose.sandbox.yml logs -f proxy app mongo",
    "k8s:apply": "kubectl apply -f ops/kubernetes/immutable-stack.yaml",
    "k8s:rotate": "kubectl rollout restart deployment/note-app deployment/note-app-proxy -n note-app",
    "k8s:teardown": "kubectl delete -f ops/kubernetes/immutable-stack.yaml",
    "check-env": "node scripts/env-check.js",
    "migrate:encrypt-at-rest": "node scripts/migrate-encryption-at-rest.js",
    "automation:trivy": "node automation/trivy-runner.js",
    "automation:falco": "node automation/falco-runner.js",
    "ml:train": "node scripts/train-alert-triage-model.js",
    "locator-repair:train": "node scripts/train-locator-repair-model.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --only note-app-web --update-env",
    "pm2:start:worker": "pm2 start ecosystem.config.cjs --only note-app-web,note-app-worker --update-env",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 delete note-app-web note-app-worker",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs note-app-web --lines 200",
    "worker": "node src/workers/realtimeProcessor.js",
    "test": "mocha --require ./test/testSetup.js \"test/**/*.js\"",
    "test:selenium": "node scripts/run-selenium-suite.js",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:e2e:theme": "playwright test playwright-tests/theme.spec.js --project=chromium",
    "test:e2e:report": "playwright show-report",
    "audit:deps": "npm audit --audit-level=high",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:report": "npm audit --json",
    "sbom:generate": "node scripts/generate-sbom.js",
    "lint": "eslint . --ext .js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k0jir0/note-app.git"
  },
  "keywords": [
    "notes",
    "note-taking",
    "security",
    "research",
    "express",
    "mongodb",
    "authentication",
    "passport",
    "ejs",
    "crud",
    "rest-api"
  ],
  "author": "Ryan V",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/k0jir0/note-app/issues"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "homepage": "https://github.com/k0jir0/note-app#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "chai": "^4.3.7",
    "eslint": "^8.57.1",
    "mocha": "^11.3.0",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.11",
    "selenium-webdriver": "^4.41.0",
    "sinon": "^21.0.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.11.3",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.1",
    "keytar": "^7.7.0",
    "mongoose": "^8.10.0",
    "passport": "^0.7.0",
    "passport-google-oidc": "^0.1.0",
    "passport-local": "^1.0.0",
    "prom-client": "^14.0.0"
  }
}
