<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= title %></title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <%- include('../partials/head-assets') %>
    <script src="/js/theme-toggle.js" defer></script>
</head>

<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Supply Chain Security Module</h1>
                <p class="text-muted mb-0">A research-facing view of committed SBOM inventory, audit commands, CI enforcement, and container hardening posture.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-outline-dark">Back to Research</a>
                <a href="/audit-telemetry/module" class="btn btn-outline-dark">Open Audit Trail and Telemetry Module</a>
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">SBOM</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.totalComponents %></p>
                        <p class="text-muted mb-0">Tracked third-party components in the committed CycloneDX manifest.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Production Graph</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.productionComponents %></p>
                        <p class="text-muted mb-0">Components currently resolved into the production dependency graph.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Development Graph</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.developmentComponents %></p>
                        <p class="text-muted mb-0">Packages present only for local tooling, tests, or CI workflows.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Hardening Checks</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.hardeningCheckCount %>/5</p>
                        <p class="text-muted mb-0">Container-path controls confirmed from the checked-in build and scan files.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-5">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Manifest</span>
                        <h2 class="h4 mt-2 mb-3">SBOM Snapshot</h2>
                        <dl class="row small mb-0">
                            <dt class="col-sm-4 text-muted">Project</dt>
                            <dd class="col-sm-8"><%= moduleData.sbom.projectName %> v<%= moduleData.sbom.projectVersion %></dd>
                            <dt class="col-sm-4 text-muted">Format</dt>
                            <dd class="col-sm-8"><%= moduleData.sbom.format %> <span class="text-muted">spec <%= moduleData.sbom.specVersion %></span></dd>
                            <dt class="col-sm-4 text-muted">Generated</dt>
                            <dd class="col-sm-8"><%= moduleData.sbom.generatedAt %></dd>
                            <dt class="col-sm-4 text-muted">Tool</dt>
                            <dd class="col-sm-8"><%= moduleData.sbom.toolName %> <span class="text-muted">v<%= moduleData.sbom.toolVersion %></span></dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-xl-7">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Audit</span>
                        <h2 class="h4 mt-2 mb-3">Local Enforcement Scripts</h2>
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Script</th>
                                        <th>Command</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% moduleData.auditScripts.forEach((script) => { %>
                                        <tr>
                                            <td><span class="badge text-bg-dark"><%= script.name %></span></td>
                                            <td><code><%= script.command %></code></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Licensing</span>
                        <h2 class="h4 mt-2 mb-3">Top License Buckets</h2>
                        <div class="row g-3">
                            <% moduleData.licenseSummary.forEach((license) => { %>
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <p class="mb-1 fw-semibold"><%= license.label %></p>
                                        <p class="text-muted small mb-0"><%= license.count %> tracked components</p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Runtime Footprint</span>
                        <h2 class="h4 mt-2 mb-3">Representative Components</h2>
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Package</th>
                                        <th>Scope</th>
                                        <th>License</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% moduleData.topComponents.forEach((component) => { %>
                                        <tr>
                                            <td>
                                                <div class="fw-semibold"><%= component.name %></div>
                                                <div class="text-muted small"><%= component.version %></div>
                                            </td>
                                            <td><span class="badge text-bg-<%= component.scope === 'Production' ? 'success' : 'secondary' %>"><%= component.scope %></span></td>
                                            <td><%= component.license %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-7">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Container Posture</span>
                        <h2 class="h4 mt-2 mb-3">Hardened Build Checks</h2>
                        <div class="d-flex flex-column gap-3">
                            <% moduleData.containerChecks.forEach((check) => { %>
                                <div class="border rounded p-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                                        <p class="fw-semibold mb-0"><%= check.label %></p>
                                        <span class="badge text-bg-<%= check.passed ? 'success' : 'secondary' %>"><%= check.passed ? 'Present' : 'Not found' %></span>
                                    </div>
                                    <p class="text-muted small mb-0"><%= check.detail %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-5">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Workflow Coverage</span>
                        <h2 class="h4 mt-2 mb-3">CI Research Notes</h2>
                        <div class="d-flex flex-column gap-3">
                            <% moduleData.workflowChecks.forEach((check) => { %>
                                <div class="border rounded p-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                                        <p class="fw-semibold mb-0"><%= check.label %></p>
                                        <span class="badge text-bg-<%= check.passed ? 'success' : 'secondary' %>"><%= check.passed ? 'Present' : 'Missing' %></span>
                                    </div>
                                    <p class="text-muted small mb-0"><%= check.detail %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>