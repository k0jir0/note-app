<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/custom.css">
    <script src="/js/theme-toggle.js" defer></script>
</head>
<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card shadow">
                    <div class="card-body text-center">
                        <h2 class="card-title mb-3">Logout</h2>
                        <p class="text-muted mb-4">Use the button below to end your current session securely.</p>
                        <form action="/auth/logout" method="POST" class="d-grid gap-2">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-outline-secondary">Logout</button>
                            <a href="/notes" class="btn btn-dark">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>