<!DOCTYPE html>
<html lang="en">
<head>

    <title><%= note ? "Edit Note" : "Create Note" %></title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">

    <script src="/js/csrf.js" defer></script>
    <script src="/js/note-form.js" defer></script>
</head>
<body>

    <div class="container mt-5">
        <h1 class="mb-4 notes-title">
            <%= note ? "Edit Note" : "Create Note" %>
        </h1>

        <form id="note-form" data-id="<%= note ? note._id : '' %>">
        
            <div class="mb-3">
                <label class="form-label" for="title">Title</label>
                <input
                    type="text"
                    name="title"
                    id="title"
                    class="form-control"
                    required
                    placeholder="Enter note title"
                    value="<%= note ? note.title : '' %>"
                />
            </div>
        
            <div class="mb-3">
                <label class="form-label" for="content">Content</label>
                <textarea
                    name="content"
                    id="content"
                    class="form-control"
                    rows="10"
                    placeholder="Write your note here..."
                ><%= note ? note.content : '' %></textarea>
            </div>
        
            <div class="mb-3">
                <label class="form-label" for="image">Image URL</label>
                <input
                    type="url"
                    name="image"
                    id="image"
                    class="form-control"
                    placeholder="https://example.com/image.jpg"
                    value="<%= note ? note.image : '' %>"
                />
            </div>

            <button type="submit" class="btn btn-dark">
                <%= note ? "Update Note" : "Create Note" %>
            </button>

            <a href="/" class="btn btn-secondary">
                Cancel</a>

        </form>
    </div>
</body>
</html>