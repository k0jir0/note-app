<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= title %></title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/browser-module-client-shared.js" defer></script>
    <script src="/js/selenium-module.js" defer></script>
</head>

<body>
    <div
        class="container mt-5 mb-5"
        id="selenium-module-root"
        data-selenium-overview-endpoint="/api/selenium/overview"
        data-selenium-script-endpoint="/api/selenium/script">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Selenium Module</h1>
                <p class="text-muted mb-2">A browser-automation workspace for planning, running, and exporting Selenium smoke coverage across the Research experience.</p>
                <p class="text-muted mb-0">Use this page to review Selenium-ready scenarios, inspect the latest suite result, understand route-level coverage, and export a starter WebDriver script tailored to this application.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-outline-dark">Back to Research</a>
                <a href="/security/module" class="btn btn-outline-dark">Open Security Module</a>
                <a href="/ml/module" class="btn btn-outline-dark">Open ML Module</a>
                <a href="/playwright/module" class="btn btn-outline-dark">Open Playwright Module</a>
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Runtime</p>
                        <p class="display-6 mb-1 fs-4" id="selenium-runtime-label">JavaScript + selenium-webdriver</p>
                        <p class="text-muted mb-0">Runtime and language used by the exported Selenium starter suite.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Scenarios</p>
                        <p class="display-6 mb-1" id="selenium-scenario-count">0</p>
                        <p class="text-muted mb-0">Registered Selenium smoke paths across auth, notes, research, and module pages.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Protected Flows</p>
                        <p class="display-6 mb-1" id="selenium-auth-count">0</p>
                        <p class="text-muted mb-0">Scenario count that reaches protected routes after creating or establishing a browser session.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Base URL</p>
                        <p class="display-6 mb-1 fs-4" id="selenium-base-url">http://localhost:3000</p>
                        <p class="text-muted mb-0">Default app origin embedded into the generated Selenium template.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                <div>
                    <span class="research-kicker">Runner</span>
                    <h2 class="h4 mt-2 mb-1">Latest Suite Run</h2>
                    <p class="text-muted mb-0">Shows the most recent Selenium results artifact generated by the live browser suite.</p>
                </div>
                <div class="d-flex gap-4 flex-wrap">
                    <div>
                        <p class="research-kicker mb-1">Implemented Scenarios</p>
                        <p class="h3 mb-1" id="selenium-suite-implemented-count">0</p>
                        <p class="text-muted small mb-0">Registered Selenium scenarios backed by executable browser tests.</p>
                    </div>
                    <div>
                        <p class="research-kicker mb-1">Latest Status</p>
                        <p class="h3 mb-1" id="selenium-latest-run-status">Unavailable</p>
                        <p class="text-muted small mb-0" id="selenium-latest-run-generated-at">No Selenium reporter output is available yet.</p>
                    </div>
                </div>
            </div>
            <div class="card-body pt-0">
                <div id="selenium-latest-run-summary" class="row g-3"></div>
                <p class="text-muted small mb-0 mt-3" id="selenium-suite-files">Suite files: waiting for module data.</p>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Selenium Controls</h2>
                    <p class="text-muted mb-1">Choose a scenario, refresh the module, load its script, or copy the current preview.</p>
                    <p class="text-muted small mb-0">These starter scripts favor durable routes and visible UI checks over brittle pixel-perfect assertions.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap align-items-center">
                    <label for="selenium-scenario-select" class="visually-hidden">Scenario</label>
                    <select id="selenium-scenario-select" class="form-select">
                        <option value="">Loading scenarios...</option>
                    </select>
                    <button type="button" id="selenium-refresh-btn" class="btn btn-dark">Refresh Module</button>
                    <button type="button" id="selenium-load-script-btn" class="btn btn-outline-dark">Load Script</button>
                    <button type="button" id="selenium-copy-script-btn" class="btn btn-outline-primary">Copy Script</button>
                </div>
            </div>
            <div class="card-body pt-0">
                <div class="mb-3">
                    <h3 class="h6 mb-2">Control Guide</h3>
                    <p class="text-muted small mb-2">Each control explains what it changes and when to use it.</p>
                    <div id="selenium-controls-guide" class="row g-3"></div>
                </div>
                <div id="selenium-status"></div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Process</span>
                        <h2 class="h4 mt-2 mb-1">Selenium Workflow</h2>
                        <p class="text-muted small mb-3">Shows the default Selenium flow from auth setup through browser assertions and results reporting.</p>
                        <div id="selenium-workflow-grid" class="d-flex flex-column gap-3"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Prerequisites</span>
                        <h2 class="h4 mt-2 mb-1">Browser Prerequisites</h2>
                        <p class="text-muted small mb-3">Required setup is separated from optional dependencies used for deeper validation.</p>
                        <div id="selenium-prerequisites-grid" class="row g-3"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body">
                <span class="research-kicker">Coverage</span>
                <h2 class="h4 mt-2 mb-1">Scenario Catalog</h2>
                <p class="text-muted small mb-3">Summarizes the routes, checks, latest run status, and optional setup for each Selenium browser path.</p>
                <div id="selenium-scenarios-grid" class="row g-3"></div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-4">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Selected</span>
                        <h2 class="h4 mt-2 mb-1">Scenario Summary</h2>
                        <p class="text-muted small mb-3">Breaks down the selected Selenium scenario before you export it into a standalone automation project.</p>
                        <div id="selenium-script-summary"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-8">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                            <div>
                                <span class="research-kicker">Export</span>
                                <h2 class="h4 mt-2 mb-1">Generated Script Preview</h2>
                                <p class="text-muted mb-0">Editable Selenium starter script generated from the selected scenario.</p>
                            </div>
                            <span class="badge text-bg-light" id="selenium-script-file-badge">No script selected</span>
                        </div>
                        <pre class="selenium-script-preview"><code id="selenium-script-code">Loading Selenium script preview...</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
