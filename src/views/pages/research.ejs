<!DOCTYPE html>
<html lang="en">

<head>
    <title>Research Workspace</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <%- include('../partials/head-assets') %>
    <script src="/js/theme-toggle.js" defer></script>
</head>

<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5 mb-5" data-automation-enabled-count="<%= workspace.automation.enabledCount %>">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Research Workspace</h1>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
                <form action="/auth/logout" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-outline-secondary">Logout</button>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <% (workspace.modules || []).forEach((module) => { %>
                <div class="col-md-6 col-xl-4">
                    <div class="card automation-card h-100">
                        <div class="card-body d-flex flex-column justify-content-between gap-3">
                            <div>
                                <span class="research-kicker"><%= module.category %></span>
                                <h2 class="h3 mt-2 mb-1"><%= module.title %></h2>
                                <p class="text-muted mb-0"><%= module.summary %></p>
                            </div>
                            <div class="d-flex gap-2 flex-wrap align-items-center">
                                <span class="badge text-bg-<%= module.badgeTone %>"><%= module.badgeText %></span>
                                <a href="<%= module.href %>" class="btn btn-<%= module.buttonVariant %>"><%= module.actionLabel %></a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>

</html>
