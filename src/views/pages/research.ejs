<!DOCTYPE html>
<html lang="en">

<head>
    <title>Research Workspace</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/custom.css">
</head>

<body>
    <div class="container mt-5 mb-5" data-automation-enabled-count="<%= workspace.automation.enabledCount %>">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Research Workspace</h1>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
                <form action="/auth/logout" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-outline-secondary">Logout</button>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-4">
                <div class="card automation-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between gap-3">
                        <div>
                            <span class="research-kicker">Primary Module</span>
                            <h2 class="h3 mt-2 mb-1">Security Module</h2>
                            <p class="text-muted mb-0">Log analysis, scan importing, correlations, automation status, and demo sample injection now live in one dedicated module page.</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                            <span class="badge text-bg-<%= workspace.automation.anyEnabled ? 'success' : 'secondary' %>"><%= workspace.automation.enabledCount %>/2 automation pollers active</span>
                            <a href="/security/module" class="btn btn-dark">Open Security Module</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card automation-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between gap-3">
                        <div>
                            <span class="research-kicker">Modeling Module</span>
                            <h2 class="h3 mt-2 mb-1">ML Module</h2>
                            <p class="text-muted mb-0">Inspect the alert triage model, review label distributions, and train a new bootstrap or hybrid model from one dedicated page.</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                            <span class="badge text-bg-info">Trainable alert triage</span>
                            <a href="/ml/module" class="btn btn-outline-dark">Open ML Module</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card automation-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between gap-3">
                        <div>
                            <span class="research-kicker">Browser Module</span>
                            <h2 class="h3 mt-2 mb-1">Selenium Module</h2>
                            <p class="text-muted mb-0">Generate Selenium WebDriver smoke suites, review browser-test coverage for this app, and export script templates tailored to the Research Workspace.</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                            <span class="badge text-bg-warning">Browser automation templates</span>
                            <a href="/selenium/module" class="btn btn-outline-dark">Open Selenium Module</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
