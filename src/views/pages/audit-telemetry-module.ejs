<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= title %></title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <%- include('../partials/head-assets') %>
    <script src="/js/theme-toggle.js" defer></script>
    <script src="/js/audit-telemetry-module.js" defer></script>
</head>

<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5 mb-5" id="audit-telemetry-module-root" data-events-endpoint="/api/audit-telemetry/events">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Audit Trail and Telemetry Module</h1>
                <p class="text-muted mb-0">A research-facing view of immutable forwarding, request-scoped DB telemetry, SIEM formatting, and response-surface hardening.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-outline-dark">Back to Research</a>
                <a href="/supply-chain/module" class="btn btn-outline-dark">Open Supply Chain Security Module</a>
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Immutable Sink</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.immutableLoggingEnabled ? 'On' : 'Off' %></p>
                        <p class="text-muted mb-0">Current runtime forwarding state for append-only operational and audit events.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Sink Format</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.format %></p>
                        <p class="text-muted mb-0">Collector-facing format for immutable log shipping.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Transport</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.tlsMode %></p>
                        <p class="text-muted mb-0">Inbound HTTPS posture when certificate-backed transport is enabled.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Coverage</p>
                        <p class="display-6 mb-1"><%= moduleData.summary.telemetryCoverageCount %></p>
                        <p class="text-muted mb-0">Telemetry categories surfaced directly in this research view.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-5">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Runtime</span>
                        <h2 class="h4 mt-2 mb-3">Immutable Logging Settings</h2>
                        <dl class="row small mb-0">
                            <dt class="col-sm-4 text-muted">Enabled</dt>
                            <dd class="col-sm-8"><%= moduleData.immutableLogging.enabled ? 'Yes' : 'No' %></dd>
                            <dt class="col-sm-4 text-muted">Endpoint</dt>
                            <dd class="col-sm-8"><%= moduleData.immutableLogging.endpoint %></dd>
                            <dt class="col-sm-4 text-muted">Source</dt>
                            <dd class="col-sm-8"><%= moduleData.immutableLogging.source %></dd>
                            <dt class="col-sm-4 text-muted">Timeout</dt>
                            <dd class="col-sm-8"><%= moduleData.immutableLogging.timeoutMs %> ms</dd>
                            <dt class="col-sm-4 text-muted">Format</dt>
                            <dd class="col-sm-8"><%= moduleData.immutableLogging.format %></dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-xl-7">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Transport</span>
                        <h2 class="h4 mt-2 mb-3">TLS and Client-Cert Posture</h2>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="border rounded p-3 h-100">
                                    <p class="fw-semibold mb-1">Protocol</p>
                                    <p class="mb-1"><%= moduleData.transport.protocol.toUpperCase() %></p>
                                    <p class="text-muted small mb-0">If HTTPS is enabled, the runtime restricts negotiation to TLS 1.3 only.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded p-3 h-100">
                                    <p class="fw-semibold mb-1">TLS Bounds</p>
                                    <p class="mb-1"><%= moduleData.transport.tlsMinVersion %> to <%= moduleData.transport.tlsMaxVersion %></p>
                                    <p class="text-muted small mb-0">The March 29 hardening removed fallback negotiation to older TLS versions.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded p-3 h-100">
                                    <p class="fw-semibold mb-1">Client Cert Requested</p>
                                    <p class="mb-1"><%= moduleData.transport.requestClientCertificate ? 'Yes' : 'No' %></p>
                                    <p class="text-muted small mb-0">The runtime can request client certificates for stronger session assurance flows.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded p-3 h-100">
                                    <p class="fw-semibold mb-1">Client Cert Required</p>
                                    <p class="mb-1"><%= moduleData.transport.requireClientCertificate ? 'Yes' : 'No' %></p>
                                    <p class="text-muted small mb-0">Mutual-TLS enforcement is separate from merely requesting a certificate.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-5">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Coverage</span>
                        <h2 class="h4 mt-2 mb-3">Telemetry Scope</h2>
                        <div class="d-flex flex-column gap-3">
                            <% moduleData.telemetryCoverage.forEach((item) => { %>
                                <div class="border rounded p-3">
                                    <p class="fw-semibold mb-1"><%= item.action %></p>
                                    <p class="text-muted small mb-0"><%= item.detail %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-7">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Posture</span>
                        <h2 class="h4 mt-2 mb-3">March 29 Control Checks</h2>
                        <div class="d-flex flex-column gap-3">
                            <% moduleData.postureChecks.forEach((check) => { %>
                                <div class="border rounded p-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                                        <p class="fw-semibold mb-0"><%= check.label %></p>
                                        <span class="badge text-bg-<%= check.passed ? 'success' : 'secondary' %>"><%= check.passed ? 'Active' : 'Passive' %></span>
                                    </div>
                                    <p class="text-muted small mb-0"><%= check.detail %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">DB Telemetry</span>
                        <h2 class="h4 mt-2 mb-3">Sample Who / What / When / Where / How Event</h2>
                        <pre class="bg-body-tertiary border rounded p-3 small mb-0 audit-prewrap"><%= moduleData.immutablePreview.sampleEventJson %></pre>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Response Surface</span>
                        <h2 class="h4 mt-2 mb-3">Sanitization Notes</h2>
                        <div class="d-flex flex-column gap-3">
                            <% moduleData.responseHardening.forEach((note) => { %>
                                <div class="border rounded p-3">
                                    <p class="text-muted small mb-0"><%= note %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Sink Preview</span>
                        <h2 class="h4 mt-2 mb-3">Structured JSON Payload</h2>
                        <p class="text-muted small">This preview shows the immutable sink body when the collector expects structured JSON.</p>
                        <pre class="bg-body-tertiary border rounded p-3 small mb-0 audit-prewrap"><%= moduleData.immutablePreview.jsonPayload %></pre>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Sink Preview</span>
                        <h2 class="h4 mt-2 mb-3">RFC 5424-Style Syslog Payload</h2>
                        <p class="text-muted small">This preview shows the same event encoded for a collector that expects syslog text.</p>
                        <pre class="bg-body-tertiary border rounded p-3 small mb-2 audit-prewrap"><%= moduleData.immutablePreview.syslogPayload %></pre>
                        <p class="text-muted small mb-0">Derived entry hash: <code><%= moduleData.immutablePreview.entryHash %></code></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card automation-card mt-4">
            <div class="card-body d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div>
                    <span class="research-kicker">History API</span>
                    <h2 class="h4 mt-2 mb-1">Persisted Audit History</h2>
                    <p class="text-muted small mb-0">This feed is backed by the local audit-event store, not just static March 29 posture notes.</p>
                </div>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <span class="badge text-bg-dark"><span id="audit-history-count">0</span> visible event(s)</span>
                    <button type="button" id="audit-history-refresh-btn" class="btn btn-outline-dark">Refresh History</button>
                </div>
            </div>
            <div class="card-body pt-0">
                <div id="audit-history-status" class="mb-3"></div>
                <div id="audit-history-grid" class="d-flex flex-column gap-3"></div>
                <div id="audit-history-pagination" class="mt-3"></div>
            </div>
        </div>
    </div>
</body>

</html>