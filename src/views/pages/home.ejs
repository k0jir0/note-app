<!DOCTYPE html>
<html>

<head>
    <title>Notes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/notes.js" defer></script>
</head>

<body>
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1>Notes</h1>
                <% if (user) { %>
                    <p class="text-muted mb-0">Welcome, <%= user.name || user.email %></p>
                <% } %>
            </div>
            <div>
                <a href="/notes/new" class="btn btn-dark me-2">Create Note</a>
                <form action="/auth/logout" method="POST" style="display: inline;">
                    <button type="submit" class="btn btn-outline-secondary">Logout</button>
                </form>
            </div>
        </div>


        <div class="row">
            <% if (notes && notes.length > 0) { %>
                <% notes.forEach(note=> { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100">
                            <% if (note.image) { %>
                                <img src="<%= note.image %>" class="card-img-top" alt="<%= note.title %>" style="height: 200px; object-fit: cover;">
                            <% } %>
                            <div class="card-body">
                                <h5 class="card-title"><%= note.title %></h5>
                                <p class="card-text text-muted">
                                    <%= note.content ? note.content.substring(0, 100) + (note.content.length > 100 ? '...' : '') : 'No content' %>
                                </p>
                                <div class="text-muted small mb-3">
                                    <i class="bi bi-calendar"></i> <%= new Date(note.createdAt).toLocaleDateString() %>
                                </div>
                                <a href="/notes/<%= note._id %>" class="btn btn-outline-dark btn-sm">View</a>
                                <a href="/notes/<%= note._id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
                                <button onclick="deleteNote('<%= note._id %>')" class="btn btn-outline-danger btn-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No notes yet. Create your first note!</p>
                    <a href="/notes/new" class="btn btn-dark">Create Note</a>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>