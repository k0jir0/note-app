<!DOCTYPE html>
<html>

<head>
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/security-scans.js" defer></script>
</head>

<body>
    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="notes-title">Vulnerability Scan Importer</h1>
                <p class="text-muted mb-0">Paste Nmap XML, Nikto output, JSON, or plain text to import findings.</p>
            </div>
            <div>
                <a href="/security/correlations" class="btn btn-outline-dark me-2">Correlations</a>
                <a href="/security/logs" class="btn btn-outline-dark me-2">Log Analysis</a>
                <a href="/notes" class="btn btn-outline-dark">Back to Notes</a>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <form id="scan-import-form">
                    <label for="rawInput" class="form-label"><strong>Scan Output</strong></label>
                    <textarea
                        id="rawInput"
                        name="rawInput"
                        class="form-control font-monospace"
                        rows="12"
                        placeholder="Paste Nmap XML, Nikto text output, JSON, or plain text scan results here..."
                        required
                    ></textarea>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted">Supported formats: Nmap XML &bull; Nikto text &bull; JSON &bull; plain text with open ports / CVEs</small>
                        <div>
                            <button type="button" id="inject-sample-scan" class="btn btn-outline-primary me-2">Load Sample Scan</button>
                            <button type="submit" class="btn btn-dark">Import Scan</button>
                        </div>
                    </div>
                </form>
                <div id="import-result" class="mt-3"></div>
            </div>
        </div>

        <h2 class="h4 mb-3">Imported Scans</h2>
        <div id="scans-grid" class="row">
            <% if (scans && scans.length > 0) { %>
                <% scans.forEach((scan) => { %>
                    <%
                        const highCount = scan.findings.filter(f => f.severity === 'high').length;
                        const medCount = scan.findings.filter(f => f.severity === 'medium').length;
                        const lowCount = scan.findings.filter(f => f.severity === 'low').length;
                        const topSeverity = highCount > 0 ? 'high' : (medCount > 0 ? 'medium' : 'low');
                    %>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 scan-result-card severity-<%= topSeverity %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <span class="badge text-bg-dark text-uppercase me-1"><%= scan.tool %></span>
                                        <span class="badge text-bg-light text-uppercase"><%= topSeverity %></span>
                                    </div>
                                    <small class="text-muted"><%= new Date(scan.importedAt).toLocaleString() %></small>
                                </div>
                                <h3 class="h6 mb-2">Target: <strong><%= scan.target %></strong></h3>
                                <div class="d-flex gap-2 mb-2">
                                    <% if (highCount > 0) { %>
                                        <span class="badge findings-badge-high"><%= highCount %> high</span>
                                    <% } %>
                                    <% if (medCount > 0) { %>
                                        <span class="badge findings-badge-medium"><%= medCount %> medium</span>
                                    <% } %>
                                    <% if (lowCount > 0) { %>
                                        <span class="badge findings-badge-low"><%= lowCount %> low</span>
                                    <% } %>
                                    <% if (scan.findings.length === 0) { %>
                                        <span class="text-muted small">No findings</span>
                                    <% } %>
                                </div>
                                <ul class="list-unstyled small text-muted mb-0">
                                    <% scan.findings.slice(0, 4).forEach((f) => { %>
                                        <li class="text-truncate">&rsaquo; <%= f.title %></li>
                                    <% }) %>
                                    <% if (scan.findings.length > 4) { %>
                                        <li class="text-muted fst-italic">... and <%= scan.findings.length - 4 %> more</li>
                                    <% } %>
                                </ul>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">No scans imported yet. Paste scan output above to get started.</div>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>
