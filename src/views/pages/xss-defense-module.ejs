<!DOCTYPE html>
<html lang="en">

<head>
    <title>XSS and CSP Defense Module</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/custom.css">
    <script src="/js/xss-defense-module.js" defer></script>
    <script src="/js/theme-toggle.js" defer></script>
</head>

<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5 mb-5"
        id="xss-defense-module-root"
        data-xss-defense-overview-endpoint="/api/xss-defense/overview"
        data-xss-defense-evaluate-endpoint="/api/xss-defense/evaluate">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <span class="research-kicker">Browser Protection</span>
                <h1 class="notes-title mb-1">XSS and CSP Defense Module</h1>
                <p class="text-muted mb-0">Review escaped rendering posture, strict Content Security Policy, and sample handling of untrusted browser content.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-secondary">Back to Research</a>
                <a href="/notes" class="btn btn-outline-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Template engine</p>
                    <p class="display-6 mb-1 fs-3" id="xss-defense-template-engine">Loading</p>
                    <p class="text-muted small mb-0">Expected server-side escaping posture</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Unescaped EJS</p>
                    <p class="display-6 mb-1 fs-3" id="xss-defense-unescaped-count">Loading</p>
                    <p class="text-muted small mb-0">Template files using unescaped output</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Inline scripts</p>
                    <p class="display-6 mb-1 fs-3" id="xss-defense-inline-script-count">Loading</p>
                    <p class="text-muted small mb-0">Page templates with inline script blocks</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">CSP script policy</p>
                    <p class="display-6 mb-1 fs-5" id="xss-defense-csp-script-src">Loading</p>
                    <p class="text-muted small mb-0">Effective script execution boundary</p>
                </div>
            </div>
        </div>

        <div class="research-summary-card p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div>
                    <p class="research-kicker mb-1">Current posture</p>
                    <p class="text-muted small mb-0" id="xss-defense-status-copy">Loading XSS-defense posture...</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" id="xss-defense-refresh-btn" class="btn btn-outline-secondary">Refresh Module</button>
                </div>
            </div>
            <div class="mt-3" id="xss-defense-status"></div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                        <div>
                            <span class="research-kicker">Architectural controls</span>
                            <h2 class="h4 mb-0">Rendering And Header Controls</h2>
                        </div>
                    </div>
                    <div id="xss-defense-controls" class="row g-3"></div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                        <div>
                            <span class="research-kicker">Content Security Policy</span>
                            <h2 class="h4 mb-0">Directive Set</h2>
                        </div>
                    </div>
                    <div id="xss-defense-csp-directives" class="d-grid gap-3"></div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                        <div>
                            <span class="research-kicker">Scenario lab</span>
                            <h2 class="h4 mb-0">Payload Evaluation</h2>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="xss-defense-scenario-select" class="form-label">Scenario</label>
                        <select id="xss-defense-scenario-select" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label for="xss-defense-payload" class="form-label">Untrusted payload</label>
                        <textarea id="xss-defense-payload" class="form-control" rows="10"></textarea>
                    </div>
                    <button type="button" id="xss-defense-evaluate-btn" class="btn btn-dark">Evaluate Payload</button>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                        <div>
                            <span class="research-kicker">Decision output</span>
                            <h2 class="h4 mb-0">Escaping And CSP Outcome</h2>
                        </div>
                    </div>
                    <div id="xss-defense-evaluation"></div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
