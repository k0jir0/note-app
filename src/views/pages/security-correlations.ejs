<!DOCTYPE html>
<html>

<head>
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/security-correlations.js" defer></script>
</head>

<body>
    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="notes-title">Correlation Dashboard</h1>
                <p class="text-muted mb-0">Link imported scan findings with observed security alerts to surface likely active risk.</p>
            </div>
            <div>
                <a href="/security/scans" class="btn btn-outline-dark me-2">Scans</a>
                <a href="/security/logs" class="btn btn-outline-dark me-2">Log Analysis</a>
                <a href="/notes" class="btn btn-outline-dark">Back to Notes</a>
            </div>
        </div>

        <div class="alert alert-secondary mb-4">
            <strong>What this page does:</strong> It connects the dots between what a scan found and what your logs are showing, so you can see when both point to the same possible problem.
            <div class="small text-muted mt-2">The alert and scan text below are short example summaries pulled from your saved data. They are meant to explain the match quickly, not show full raw logs.</div>
        </div>

        <div class="card mb-4">
            <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Demo Injection</h2>
                    <p class="text-muted mb-0">This page starts blank. Click the button to inject example scan and log data and draw sample correlations.</p>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" id="inject-sample-correlations" class="btn btn-dark">Inject Sample Logs</button>
                    <button type="button" id="clear-correlations" class="btn btn-outline-secondary">Clear</button>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4" id="correlation-overview">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1">Correlation Matches</p>
                        <p class="display-6 mb-0"><%= overview.total %></p>
                        <p class="small text-muted mb-0">How many scan findings and security alerts appear to describe the same issue.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1">High Priority</p>
                        <p class="display-6 mb-0"><%= overview.highPriority %></p>
                        <p class="small text-muted mb-0">How many of those matches look serious and should be reviewed first.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1">Distinct Targets</p>
                        <p class="display-6 mb-0"><%= overview.targets %></p>
                        <p class="small text-muted mb-0">How many different systems or hosts are involved in the matches shown below.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">Recent Correlations</h2>
            <button type="button" id="refresh-correlations" class="btn btn-dark">Refresh</button>
        </div>

        <div id="correlation-result" class="mb-3"></div>

        <div id="correlations-grid" class="row">
            <% if (correlations && correlations.length > 0) { %>
                <% correlations.forEach((correlation) => { %>
                    <div class="col-lg-6 mb-3">
                        <div class="card h-100 correlation-card severity-<%= correlation.severity %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <span class="badge text-bg-light text-uppercase me-1"><%= correlation.severity %></span>
                                        <span class="badge text-bg-dark text-uppercase"><%= correlation.scan.tool %></span>
                                    </div>
                                    <small class="text-muted"><%= new Date(correlation.alert.detectedAt || correlation.scan.importedAt).toLocaleString() %></small>
                                </div>
                                <h3 class="h6 mb-2"><%= correlation.headline %></h3>
                                <p class="text-muted small mb-2">Target: <strong><%= correlation.target %></strong></p>

                                <div class="mb-3">
                                    <p class="small fw-semibold mb-2">Why the app thinks these belong together:</p>
                                    <% correlation.rationale.forEach((reason) => { %>
                                        <div class="correlation-reason">&rsaquo; <%= reason %></div>
                                    <% }) %>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <% if (correlation.matchedIndicators.ips && correlation.matchedIndicators.ips.length > 0) { %>
                                        <span class="badge correlation-chip">IPs: <%= correlation.matchedIndicators.ips.join(', ') %></span>
                                    <% } %>
                                    <% if (correlation.matchedIndicators.tools && correlation.matchedIndicators.tools.length > 0) { %>
                                        <span class="badge correlation-chip">Tools: <%= correlation.matchedIndicators.tools.join(', ') %></span>
                                    <% } %>
                                    <% if (correlation.matchedIndicators.webFindingCount > 0) { %>
                                        <span class="badge correlation-chip"><%= correlation.matchedIndicators.webFindingCount %> web finding(s)</span>
                                    <% } %>
                                    <% if (correlation.matchedIndicators.authFindingCount > 0) { %>
                                        <span class="badge correlation-chip"><%= correlation.matchedIndicators.authFindingCount %> auth finding(s)</span>
                                    <% } %>
                                </div>

                                <p class="small text-muted mb-1">This card combines one alert with one scan result that likely describe the same risk.</p>
                                <p class="small text-muted mb-1">The lines below are concise examples of what was detected, not full log dumps.</p>
                                <p class="small mb-1"><strong>Alert:</strong> <%= correlation.alert.summary %></p>
                                <p class="small text-muted mb-2"><strong>Scan:</strong> <%= correlation.scan.summary %></p>

                                <p class="small fw-semibold mb-1">Top scan findings behind this match:</p>
                                <ul class="list-unstyled small text-muted mb-0">
                                    <% correlation.scan.topFindings.forEach((finding) => { %>
                                        <li>&rsaquo; <%= finding.title %> (<%= finding.severity %>)</li>
                                    <% }) %>
                                </ul>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">No recent correlations yet. Inject sample logs to draw example matches here.</div>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>