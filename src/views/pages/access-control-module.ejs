<!DOCTYPE html>
<html lang="en">

<head>
    <title>Server Access Control Module</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/custom.css">
    <script src="/js/access-control-module.js" defer></script>
    <script src="/js/theme-toggle.js" defer></script>
</head>

<body class="<%= (user && user.preferences && user.preferences.nightMode) ? 'dark-mode' : '' %>">
    <%- include('../partials/theme-toggle') %>
    <div class="container mt-5 mb-5"
        id="access-control-module-root"
        data-access-control-overview-endpoint="/api/access-control/overview"
        data-access-control-evaluate-endpoint="/api/access-control/evaluate">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <span class="research-kicker">Authorization Module</span>
                <h1 class="notes-title mb-1">Server Access Control Module</h1>
                <p class="text-muted mb-0">Review server-side identity verification, protected API coverage, and how the app blocks broken-access-control scenarios even when the frontend is bypassed.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-secondary">Back to Research</a>
                <a href="/notes" class="btn btn-outline-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Protected routes</p>
                    <p class="display-6 mb-1 fs-3" id="access-control-route-count">Loading</p>
                    <p class="text-muted small mb-0">API routes covered by the server-side access gate</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Route-level auth</p>
                    <p class="display-6 mb-1 fs-3" id="access-control-route-auth-count">Loading</p>
                    <p class="text-muted small mb-0">Routes that still keep explicit auth middleware in the router</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Mission policy</p>
                    <p class="display-6 mb-1 fs-3" id="access-control-mission-count">Loading</p>
                    <p class="text-muted small mb-0">Routes with role and mission policy checks layered on top</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="research-summary-card p-3 h-100">
                    <p class="research-kicker mb-2">Public exceptions</p>
                    <p class="display-6 mb-1 fs-3" id="access-control-public-count">Loading</p>
                    <p class="text-muted small mb-0">Explicit paths allowed to bypass the API identity gate</p>
                </div>
            </div>
        </div>

        <div class="research-summary-card p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div>
                    <p class="research-kicker mb-1">Current posture</p>
                    <p class="text-muted small mb-0" id="access-control-status-copy">Loading access-control posture...</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" id="access-control-refresh-btn" class="btn btn-outline-secondary">Refresh Module</button>
                </div>
            </div>
            <div class="mt-3" id="access-control-status"></div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <span class="research-kicker">Architectural controls</span>
                    <h2 class="h4 mb-3">Server-Side Enforcement</h2>
                    <div id="access-control-controls" class="row g-3"></div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <span class="research-kicker">Current identity</span>
                    <h2 class="h4 mb-3">Verified Server Context</h2>
                    <div id="access-control-current-identity"></div>
                </div>
            </div>

            <div class="col-12">
                <div class="research-panel">
                    <span class="research-kicker">Route coverage</span>
                    <h2 class="h4 mb-3">Protected API Catalog</h2>
                    <div id="access-control-route-catalog" class="row g-3"></div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <span class="research-kicker">Scenario lab</span>
                    <h2 class="h4 mb-3">Broken Access Control Simulation</h2>
                    <div class="mb-3">
                        <label for="access-control-scenario-select" class="form-label">Scenario</label>
                        <select id="access-control-scenario-select" class="form-select"></select>
                    </div>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="form-label" for="access-control-authenticated">Authenticated</label>
                            <select id="access-control-authenticated" class="form-select">
                                <option value="true">true</option>
                                <option value="false">false</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label" for="access-control-server-identity">Server identity verified</label>
                            <select id="access-control-server-identity" class="form-select">
                                <option value="true">true</option>
                                <option value="false">false</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label" for="access-control-owned-resource">Owns resource</label>
                            <select id="access-control-owned-resource" class="form-select">
                                <option value="true">true</option>
                                <option value="false">false</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label" for="access-control-frontend-visible">Frontend shows control</label>
                            <select id="access-control-frontend-visible" class="form-select">
                                <option value="true">true</option>
                                <option value="false">false</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="access-control-mission-role">Mission role</label>
                            <select id="access-control-mission-role" class="form-select">
                                <option value="operator">operator</option>
                                <option value="analyst" selected>analyst</option>
                                <option value="mission_lead">mission_lead</option>
                                <option value="auditor">auditor</option>
                                <option value="admin">admin</option>
                                <option value="break_glass">break_glass</option>
                            </select>
                        </div>
                    </div>
                    <button type="button" id="access-control-evaluate-btn" class="btn btn-dark mt-3">Evaluate Access</button>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="research-panel h-100">
                    <span class="research-kicker">Decision output</span>
                    <h2 class="h4 mb-3">Server Decision</h2>
                    <div id="access-control-evaluation"></div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
