<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= title %></title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/playwright-module.js" defer></script>
</head>

<body>
    <div
        class="container mt-5 mb-5"
        id="playwright-module-root"
        data-playwright-overview-endpoint="/api/playwright/overview"
        data-playwright-script-endpoint="/api/playwright/script">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h1 class="notes-title mb-1">Playwright Module</h1>
                <p class="text-muted mb-2">A browser-automation workspace for planning and exporting Playwright smoke coverage across the Research experience.</p>
                <p class="text-muted mb-0">Choose a scenario, review its routes and checks, then export a starter spec for local testing or CI.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/research" class="btn btn-outline-dark">Back to Research</a>
                <a href="/security/module" class="btn btn-outline-dark">Open Security Module</a>
                <a href="/ml/module" class="btn btn-outline-dark">Open ML Module</a>
                <a href="/selenium/module" class="btn btn-outline-dark">Open Selenium Module</a>
                <a href="/notes" class="btn btn-secondary">Back to Notes</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-5">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Runtime</p>
                        <p class="playwright-runtime-label mb-1" id="playwright-runtime-label">JavaScript + @playwright/test</p>
                        <p class="text-muted mb-0">Default language and runner for the exported Playwright specs.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-2">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Scenarios</p>
                        <p class="display-6 mb-1" id="playwright-scenario-count">0</p>
                        <p class="text-muted mb-0">Smoke paths currently defined for the Research workspace and module pages.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-2">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Protected Flows</p>
                        <p class="display-6 mb-1" id="playwright-auth-count">0</p>
                        <p class="text-muted mb-0">Scenarios that sign in before they visit protected routes.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card research-summary-card h-100">
                    <div class="card-body">
                        <p class="research-kicker mb-2">Base URL</p>
                        <p class="display-6 mb-1 fs-4" id="playwright-base-url">http://localhost:3000</p>
                        <p class="text-muted mb-0">Default app origin injected into the exported spec.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                <div>
                    <span class="research-kicker">Runner</span>
                    <h2 class="h4 mt-2 mb-1">Latest Suite Run</h2>
                    <p class="text-muted mb-0">Shows the latest Playwright JSON report generated by the real browser test runner.</p>
                </div>
                <div class="d-flex gap-4 flex-wrap">
                    <div>
                        <p class="research-kicker mb-1">Implemented Scenarios</p>
                        <p class="h3 mb-1" id="playwright-suite-implemented-count">0</p>
                        <p class="text-muted small mb-0">Shared scenarios backed by executable Playwright tests.</p>
                    </div>
                    <div>
                        <p class="research-kicker mb-1">Latest Status</p>
                        <p class="h3 mb-1" id="playwright-latest-run-status">Unavailable</p>
                        <p class="text-muted small mb-0" id="playwright-latest-run-generated-at">No Playwright reporter output is available yet.</p>
                    </div>
                </div>
            </div>
            <div class="card-body pt-0">
                <div id="playwright-latest-run-summary" class="row g-3"></div>
                <p class="text-muted small mb-0 mt-3" id="playwright-suite-files">Suite files: waiting for module data.</p>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Playwright Controls</h2>
                    <p class="text-muted mb-1">Choose a scenario, refresh the catalog, load its spec, or copy the current preview.</p>
                    <p class="text-muted small mb-0">These starter specs favor stable routes and visible UI checks over brittle interaction chains.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap align-items-center">
                    <label for="playwright-scenario-select" class="visually-hidden">Scenario</label>
                    <select id="playwright-scenario-select" class="form-select">
                        <option value="">Loading scenarios...</option>
                    </select>
                    <button type="button" id="playwright-refresh-btn" class="btn btn-dark">Refresh Module</button>
                    <button type="button" id="playwright-load-script-btn" class="btn btn-outline-dark">Load Spec</button>
                    <button type="button" id="playwright-copy-script-btn" class="btn btn-outline-primary">Copy Spec</button>
                </div>
            </div>
            <div class="card-body pt-0">
                <div class="mb-3">
                    <h3 class="h6 mb-2">Control Guide</h3>
                    <p class="text-muted small mb-2">Each control explains what it changes and when to use it.</p>
                    <div id="playwright-controls-guide" class="row g-3"></div>
                </div>
                <div id="playwright-status"></div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Process</span>
                        <h2 class="h4 mt-2 mb-1">Playwright Workflow</h2>
                        <p class="text-muted small mb-3">Shows the default flow for an exported smoke test from sign-in through handoff.</p>
                        <div id="playwright-workflow-grid" class="d-flex flex-column gap-3"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Prerequisites</span>
                        <h2 class="h4 mt-2 mb-1">Playwright Prerequisites</h2>
                        <p class="text-muted small mb-3">Required setup is separated from optional dependencies used for deeper validation.</p>
                        <div id="playwright-prerequisites-grid" class="row g-3"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card automation-card mb-4">
            <div class="card-body">
                <span class="research-kicker">Coverage</span>
                <h2 class="h4 mt-2 mb-1">Scenario Catalog</h2>
                <p class="text-muted small mb-3">Summarizes the routes, checks, and optional setup for each smoke path.</p>
                <div id="playwright-scenarios-grid" class="row g-3"></div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-4">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <span class="research-kicker">Selected</span>
                        <h2 class="h4 mt-2 mb-1">Scenario Summary</h2>
                        <p class="text-muted small mb-3">Breaks down the selected spec before you export it into a Playwright project.</p>
                        <div id="playwright-script-summary"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-8">
                <div class="card automation-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
                            <div>
                                <span class="research-kicker">Export</span>
                                <h2 class="h4 mt-2 mb-1">Generated Spec Preview</h2>
                                <p class="text-muted mb-0">Editable starter spec generated from the selected scenario.</p>
                            </div>
                            <span class="badge text-bg-light" id="playwright-script-file-badge">No spec selected</span>
                        </div>
                        <pre class="playwright-script-preview"><code id="playwright-script-code">Loading spec preview...</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
