<!DOCTYPE html>
<html>

<head>
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/security-logs.js" defer></script>
</head>

<body>
    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="notes-title">Log Analysis Assistant</h1>
                <p class="text-muted mb-0">Paste server logs to detect suspicious patterns.</p>
            </div>
            <div>
                <a href="/notes" class="btn btn-outline-dark">Back to Notes</a>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <form id="log-analysis-form">
                    <label for="logText" class="form-label"><strong>Log Input</strong></label>
                    <textarea
                        id="logText"
                        name="logText"
                        class="form-control"
                        rows="10"
                        placeholder="Paste Apache, Nginx, auth, or app logs here..."
                        required
                    ></textarea>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted">Tip: include timestamps, IPs, and status codes for best detection.</small>
                        <div>
                            <button type="button" id="inject-fake-log" class="btn btn-outline-primary me-2">Load Sample Log</button>
                            <button type="submit" class="btn btn-dark">Analyze Logs</button>
                        </div>
                    </div>
                </form>
                <div id="analysis-result" class="mt-3"></div>
            </div>
        </div>

        <h2 class="h4 mb-3">Recent Alerts</h2>
        <div id="alerts-grid" class="row">
            <% if (alerts && alerts.length > 0) { %>
                <% alerts.forEach((alert) => { %>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 security-alert-card severity-<%= alert.severity %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="badge text-bg-light text-uppercase"><%= alert.severity %></span>
                                    <small class="text-muted"><%= new Date(alert.detectedAt).toLocaleString() %></small>
                                </div>
                                <h3 class="h6 mb-2"><%= alert.summary %></h3>
                                <p class="text-muted small mb-0">Type: <%= alert.type %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">No security alerts yet. Analyze logs to generate alerts.</div>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>
